# Copy this file to .env and fill values locally.
# Do not commit real secrets.

DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=

# Optional. If set, latest-news/context lookup uses Tavily first.
# If empty, it falls back to the free Google News RSS source.
TAVILY_API_KEY=
FRESH_SEARCH_PROVIDER=auto

# NoneBot listens here. Configure NapCat reverse WebSocket to:
# ws://127.0.0.1:8080/onebot/v11/ws
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO

# Replace with your own QQ number if you want admin commands.
SUPERUSERS=["123456789"]
NICKNAME=["张老师","升学张老师","报考张老师"]
COMMAND_START=["/"]
